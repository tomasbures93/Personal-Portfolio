## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# Visual Studio files
*.cache
*.dbmdl
*.opendb
*.VC.db
*.VC.VC.opendb

# .NET
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# VS Code
.vscode/

# Rider
.idea/

# NuGet
*.nupkg
packages/
!packages/build/
!packages/repositories.config

# Logs
*.log

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# SQLite / local db if not meant for repo
*.sqlite
*.sqlite3